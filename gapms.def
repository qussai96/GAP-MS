Bootstrap: docker
From: continuumio/miniconda3:23.3.1-0

%files
    gapms /opt/gapms/gapms
    setup.py /opt/gapms/setup.py
    pyproject.toml /opt/gapms/pyproject.toml
    README.md /opt/gapms/README.md
    requirements.txt /opt/gapms/requirements.txt
    xgb_protein_classifier.pkl /opt/gapms/xgb_protein_classifier.pkl

%post
    set -e

    # Configure Conda channels
    conda config --add channels conda-forge
    conda config --add channels bioconda

    # Create the runtime environment
    conda create -y -n gapms_env \
        python=3.10 \
        pip \
        perl \
        perl-xml-parser \
        perl-xml-twig \
        gffread \
        gffcompare \
        samtools \
        stringtie \
        transdecoder

    . /opt/conda/etc/profile.d/conda.sh
    conda activate gapms_env

    # Install GAP-MS from the copied source tree
    cd /opt/gapms
    pip install --no-cache-dir --upgrade pip setuptools wheel
    pip install --no-cache-dir .

    # Clean caches to reduce image size
    conda clean --all -y
    rm -rf /root/.cache/pip

%environment
    export PATH=/opt/conda/envs/gapms_env/bin:$PATH
    export CONDA_DEFAULT_ENV=gapms_env
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    exec /opt/conda/envs/gapms_env/bin/gapms "$@"

%labels
    Author Qussai Abbas
    Version 0.1.3
    Description GAP-MS: Gene Model Assessment using Peptides from Mass Spectrometry

%help
    GAP-MS evaluates predicted gene models by integrating peptide evidence
    from mass spectrometry with in-silico gene predictions.

    This image includes the external tools used by the pipeline:
        gffread, gffcompare, samtools, StringTie, and TransDecoder

    Example usage:
        apptainer run gapms.sif -g annotations.gtf -f proteins.fasta -p peptides.txt

    With BAM input:
        apptainer exec gapms.sif gapms -b rnaseq.bam -a assembly.fasta -p peptides.txt

    With both prediction + BAM branches and reference comparison:
        apptainer exec gapms.sif gapms \
            -g predictions.gtf -b rnaseq.bam -a assembly.fasta -p peptides.txt \
            -rg reference.gtf -rf reference.faa

    For more information:
        apptainer exec gapms.sif gapms --help
